/**
 * udp_receiver.ino  (for ESP8266 / ESP32)
 * 
 * Receives UDP packets from the Android face detection app
 * and forwards them to the Arduino main controller via Serial.
 *
 * Wiring:
 *   ESP8266 TX  → Arduino RX (pin 0 on Uno; use SoftwareSerial for Mega)
 *   ESP8266 RX  → Arduino TX
 *   ESP8266 GND → Arduino GND
 *   ESP8266 VCC → 3.3V (use a level shifter for 5V Arduino!)
 *
 * UDP Packet (7 bytes):
 *   [0xAA] [error_x LSB] [error_x MSB] [error_y LSB] [error_y MSB]
 *   [face_width LSB] [face_width MSB] [XOR checksum]
 *
 * Author:Afreed
 * Date:    2024
 * License: MIT
 */

#ifdef ESP8266
  #include <ESP8266WiFi.h>
  #include <WiFiUdp.h>
#else
  #include <WiFi.h>
  #include <WiFiUdp.h>
#endif

// ============================================================
//  Wi-Fi & Network Configuration  ← Change these!
// ============================================================
const char* SSID       = "YOUR_WIFI_SSID";
const char* PASSWORD   = "YOUR_WIFI_PASSWORD";
const uint16_t UDP_PORT = 5005;

// ============================================================
//  PACKET FORMAT
// ============================================================
#define PACKET_HEADER  0xAA
#define PACKET_SIZE    7

WiFiUDP udp;
uint8_t packetBuf[128];

void setup() {
    Serial.begin(115200);
    delay(500);
    Serial.println("\n[ESP] UDP Receiver Starting...");

    // Connect to Wi-Fi
    WiFi.begin(SSID, PASSWORD);
    Serial.print("[ESP] Connecting to WiFi");
    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED && attempts < 30) {
        delay(500);
        Serial.print(".");
        attempts++;
    }

    if (WiFi.status() == WL_CONNECTED) {
        Serial.println("\n[ESP] WiFi Connected!");
        Serial.print("[ESP] IP Address: ");
        Serial.println(WiFi.localIP());
        udp.begin(UDP_PORT);
        Serial.print("[ESP] Listening on UDP port: ");
        Serial.println(UDP_PORT);
    } else {
        Serial.println("\n[ESP] WiFi FAILED. Check credentials.");
        while (true) { delay(1000); }   // halt
    }
}

void loop() {
    int packetSize = udp.parsePacket();

    if (packetSize == PACKET_SIZE) {
        udp.read(packetBuf, PACKET_SIZE);

        // Validate header
        if (packetBuf[0] != PACKET_HEADER) return;

        // Validate XOR checksum
        uint8_t chk = 0;
        for (int i = 1; i < PACKET_SIZE - 1; i++) chk ^= packetBuf[i];
        if (chk != packetBuf[PACKET_SIZE - 1]) return;  // corrupted

        // Forward to Arduino via Serial
        Serial.write(packetBuf, PACKET_SIZE);
    }
}
